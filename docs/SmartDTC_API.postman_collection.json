        {
          "name": "Update Route",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/routes/{{routeId}}", "host": ["{{baseUrl}}"], "path": ["routes","{{routeId}}"] },
            "body": {
              "mode": "raw",
              "raw": "{ \"estimatedDuration\": 60, \"isActive\": true }"
            }
          },
          "response": []
        },
        {
          "name": "Delete Route",
          "request": {
            "method": "DELETE",
            "url": { "raw": "{{baseUrl}}/routes/{{routeId}}", "host": ["{{baseUrl}}"], "path": ["routes","{{routeId}}"] }
          },
          "response": []
        }
      ]
    },
